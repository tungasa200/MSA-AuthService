# JWT
JWT_SECRET=your_jwt_secret_here_minimum_64_characters_long

# Crypto
CRYPTO_SALT_KEY=your_crypto_salt_key

# Redis
REDIS_HOST=your_redis_host
REDIS_PASSWORD=your_redis_password

# Service DB (yvisbig-auth)
SERVICE_DB_HOST=your_service_db_host
SERVICE_DB_PORT=3306
SERVICE_DB_USERNAME=your_db_username
SERVICE_DB_PASSWORD=your_db_password

# API DB (yvisbig-api)
DB_HOST=your_db_host
DB_PORT=3306
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Media
MEDIA_ID=your_media_id
MEDIA_KEY=your_media_key
MEDIA_SECRET=your_media_secret

# Kakao OAuth
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# Naver OAuth
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
